# Cisco target
CAT8K_HOST=devnetsandboxiosxec8k.cisco.com
CAT8K_USERNAME=replace-me
CAT8K_PASSWORD=replace-me
CAT8K_SSH_PORT=22
CAT8K_RESTCONF_PORT=443

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=replace-me
OPENAI_MODEL=replace-me

# Optional local fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=replace-me

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Agent persistence
LANGGRAPH_CHECKPOINTER=memory
LANGGRAPH_DB_PATH=./agent.db

